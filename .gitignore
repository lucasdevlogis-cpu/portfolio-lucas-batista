# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/
/out/
/dist/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# python (demos-logistica)
__pycache__/
*.py[cod]
.venv/

.vercel
.env*

# audit artifacts
lighthouse-*.json
cv-export.json
.tmp-lh/
wb-*.json

# exceções ao gitignore global (*token* — secrets, não design docs)
!design/tokens.md
!design/archive/tokens-layout-comercial-2026-07.md
