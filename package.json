{
  "name": "portfolio-lucas-batista",
  "version": "0.1.0",
  "private": true,
  "overrides": {
    "postcss": "8.5.15"
  },
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "next dev",
    "validate": "npm run tokens:check && tsx scripts/validate-cases.ts && npm run demos:validate",
    "prebuild": "npm run validate && npm run typecheck && npm run seo:generate",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "seo:generate": "tsx scripts/generate-seo-files.ts",
    "tokens:sync": "node scripts/generate-design-tokens.mjs",
    "tokens:check": "node scripts/generate-design-tokens.mjs --check",
    "demos:export": "python demos-logistica/scripts/export_demo_snapshots.py",
    "demos:validate": "tsx scripts/validate-demo-contract.ts",
    "lighthouse:desktop": "node scripts/run-lighthouse.mjs desktop",
    "lighthouse:mobile": "node scripts/run-lighthouse.mjs mobile",
    "lighthouse:all": "npm run lighthouse:desktop && npm run lighthouse:mobile",
    "qa:visual": "node docs/audit/scripts/qa-verify.mjs && node docs/audit/scripts/qa-viewport-captures.mjs",
    "cv:export": "tsx scripts/export-cv-content.ts",
    "cv:generate": "npm run cv:export && python scripts/generate-cv-pdf.py",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@vercel/analytics": "^2.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "echarts": "^6.1.0",
    "framer-motion": "^12.42.0",
    "lucide-react": "^1.21.0",
    "maplibre-gl": "^5.24.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "lighthouse": "^13.4.1",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5",
    "ws": "^8.21.0"
  }
}
