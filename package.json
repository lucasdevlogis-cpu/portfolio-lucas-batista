{
  "name": "portfolio-lucas-batista",
  "version": "0.1.0",
  "private": true,
  "overrides": {
    "postcss": "8.5.15"
  },
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "next dev",
    "validate": "npm run tokens:check && node scripts/validate-architecture.mjs && tsx scripts/validate-cases.ts && npm run demos:validate",
    "prebuild": "npm run validate && npm run typecheck",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:python": "python -m ruff check apps/demos",
    "format": "npm run format:prettier && npm run format:python",
    "format:check": "npm run format:prettier:check && python -m ruff format --check apps/demos",
    "format:prettier": "prettier --write README.md AGENTS.md \"*.{json,mjs,ts,md,code-workspace}\" \".codex/**/*.md\" \".cursor/**/*.{json,md}\" \".github/**/*.{yml,yaml}\" \"app/**/*.{ts,tsx,css}\" \"components/**/*.{ts,tsx}\" \"contracts/**/*.json\" \"data/**/*.ts\" \"design/**/*.{md,json}\" \"docs/**/*.md\" \"lib/**/*.{ts,tsx}\" \"scripts/**/*.{ts,mjs}\" \"tests/**/*.{ts,tsx}\" \"apps/demos/**/*.md\"",
    "format:prettier:check": "prettier --check README.md AGENTS.md \"*.{json,mjs,ts,md,code-workspace}\" \".codex/**/*.md\" \".cursor/**/*.{json,md}\" \".github/**/*.{yml,yaml}\" \"app/**/*.{ts,tsx,css}\" \"components/**/*.{ts,tsx}\" \"contracts/**/*.json\" \"data/**/*.ts\" \"design/**/*.{md,json}\" \"docs/**/*.md\" \"lib/**/*.{ts,tsx}\" \"scripts/**/*.{ts,mjs}\" \"tests/**/*.{ts,tsx}\" \"apps/demos/**/*.md\"",
    "format:python": "python -m ruff format apps/demos",
    "typecheck": "tsc --noEmit",
    "tokens:sync": "node scripts/generate-design-tokens.mjs",
    "tokens:check": "node scripts/generate-design-tokens.mjs --check",
    "demos:build": "python apps/demos/scripts/build_datasets.py",
    "demos:export": "python apps/demos/scripts/export_demo_snapshots.py",
    "demos:test": "python -m pytest",
    "demos:smoke": "python apps/demos/scripts/smoke_test.py",
    "demos:validate": "tsx scripts/validate-demo-contract.ts",
    "lighthouse:desktop": "node scripts/run-lighthouse.mjs desktop",
    "lighthouse:mobile": "node scripts/run-lighthouse.mjs mobile",
    "lighthouse:all": "npm run lighthouse:desktop && npm run lighthouse:mobile",
    "qa:visual": "node scripts/qa/qa-verify.mjs && node scripts/qa/qa-viewport-captures.mjs",
    "qa:streamlit": "node scripts/qa/qa-streamlit.mjs",
    "cv:export": "tsx scripts/export-cv-content.ts",
    "cv:generate": "npm run cv:export && python scripts/generate-cv-pdf.py",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "verify": "npm run format:check && npm run lint && npm run lint:python && npm run demos:test && npm run build",
    "verify:full": "npm run verify && npm run demos:smoke && npm run test:e2e && npm audit --audit-level=moderate"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@vercel/analytics": "^2.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "echarts": "^6.1.0",
    "lucide-react": "^1.21.0",
    "maplibre-gl": "^5.24.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "lighthouse": "^13.4.1",
    "prettier": "^3.9.5",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5",
    "ws": "^8.21.0"
  }
}
